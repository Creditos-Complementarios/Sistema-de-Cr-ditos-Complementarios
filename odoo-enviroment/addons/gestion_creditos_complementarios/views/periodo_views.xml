<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================== -->
    <!--  Periodo Escolar                              -->
    <!-- ============================================== -->

    <record id="view_periodo_list" model="ir.ui.view">
        <field name="name">creditos.periodo.list</field>
        <field name="model">creditos.periodo</field>
        <field name="arch" type="xml">
            <list string="Periodos Escolares">
                <field name="clave_periodo"/>
                <field name="descripcion"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_periodo_form" model="ir.ui.view">
        <field name="name">creditos.periodo.form</field>
        <field name="model">creditos.periodo</field>
        <field name="arch" type="xml">
            <form string="Periodo Escolar">
                <sheet>
                    <group string="Datos del Periodo">
                        <field name="clave_periodo"/>
                        <field name="descripcion"/>
                        <field name="fecha_inicio"/>
                        <field name="fecha_fin"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Fechas de Inscripción">
                            <field name="fecha_por_periodo_ids">
                                <list editable="bottom">
                                    <field name="fecha_inicio"/>
                                    <field name="fecha_fin"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_periodo" model="ir.actions.act_window">
        <field name="name">Periodos Escolares</field>
        <field name="res_model">creditos.periodo</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Formulario principal -->
    <record id="view_actividad_complementaria_form" model="ir.ui.view">
        <field name="name">creditos.actividad.complementaria.form</field>
        <field name="model">creditos.actividad.complementaria</field>
        <field name="arch" type="xml">
            <form string="Actividad Complementaria">

                <!-- Barra de estado y acciones -->
                <header>
                    <!-- Acciones disponibles según estado -->
                    <button name="action_enviar_catalogo"
                            string="Enviar al Catálogo"
                            type="object"
                            class="btn-primary"
                            invisible="estado_actividad != 'aprobada'"
                            groups="gestion_creditos_complementarios.group_jefe_departamento"
                            confirm="¿Confirma el envío de esta actividad al catálogo?"/>
                    <button name="action_difundir_actividad"
                            string="Difundir Actividad"
                            type="object"
                            class="btn-secondary"
                            invisible="estado_actividad != 'pendiente_inicio'"
                            groups="gestion_creditos_complementarios.group_jefe_departamento"/>
                    <button name="action_firmar_constancias"
                            string="Firmar Constancias"
                            type="object"
                            class="btn-primary"
                            invisible="estado_actividad != 'finalizada'"
                            groups="gestion_creditos_complementarios.group_jefe_departamento"
                            confirm="¿Confirma la firma de todas las constancias? Esta acción replicará su firma a todos los estudiantes."/>
                    <field name="estado_actividad" widget="statusbar"
                           statusbar_visible="aprobada,pendiente_inicio,en_curso,finalizada"/>
                </header>

                <sheet>
                    <!-- Imagen y título -->
                    <field name="ruta_imagen" widget="image" class="oe_avatar"/>
                    <field name="constancias_listas" invisible="1"/>
                    <div class="oe_title">
                        <label for="nombre_actividad"/>
                        <h1>
                            <field name="nombre_actividad"
                                   readonly="estado_actividad != 'aprobada'"/>
                        </h1>
                    </div>

                    <!-- Alerta actividad rechazada -->
                    <div class="alert alert-danger" role="alert"
                         invisible="estado_actividad != 'rechazada'">
                        <i class="fa fa-times-circle"/>
                        <strong>Esta actividad fue rechazada.</strong>
                        Solo puede consultarse como referencia.
                    </div>

                    <!-- Alerta constancias listas -->
                    <div class="alert alert-success" role="alert"
                         invisible="not constancias_listas">
                        <i class="fa fa-check-circle"/>
                        Todos los estudiantes tienen nivel de desempeño asignado.
                        <strong>Las constancias están listas para firma.</strong>
                    </div>

                    <!-- Sección 1: Datos generales -->
                    <group string="Datos Generales">
                        <group>
                            <field name="tipo_actividad_id"
                                   options="{'no_create': True}"
                                   readonly="1"/>
                            <field name="departamento_id"
                                   options="{'no_create': True}"
                                   readonly="estado_actividad != 'aprobada'"/>
                            <field name="periodo_id"
                                   options="{'no_create': True}"
                                   readonly="1"/>
                        </group>
                        <group>
                            <field name="jefe_departamento_id"
                                   options="{'no_create': True}"
                                   domain="[('creditos_es_jefe_depto', '=', True)]"
                                   readonly="1"/>
                            <field name="fecha_inicio"
                                   readonly="estado_actividad != 'aprobada'"/>
                            <field name="fecha_fin"
                                   readonly="estado_actividad != 'aprobada'"/>
                        </group>
                    </group>

                    <!-- Sección 2: Responsable de Actividad -->
                    <group string="Responsable de Actividad">
                        <group>
                            <field name="responsable_actividad_id"
                                   options="{'no_create': True}"
                                   domain="[('creditos_es_responsable_designado', '=', True)]"
                                   readonly="estado_actividad != 'aprobada' and estado_actividad != 'en_curso'"
                                   help="Solo se muestran responsables designados por el Coordinador de Carrera."/>
                        </group>
                        <group>
                            <div class="text-muted"
                                 invisible="responsable_actividad_id != False">
                                <i class="fa fa-exclamation-triangle text-warning"/>
                                Se requiere asignar un Responsable antes de inscribir
                                estudiantes o enviar al catálogo.
                            </div>
                        </group>
                    </group>

                    <!-- Sección 3: Créditos y horas -->
                    <group string="Créditos y Duración">
                        <group>
                            <field name="cantidad_horas"
                                   readonly="estado_actividad != 'aprobada'"/>
                            <!-- Créditos: solo 1 o 0.5 -->
                            <field name="creditos"
                                   widget="radio"
                                   readonly="estado_actividad != 'aprobada'"
                                   help="1 crédito o 0.5 créditos. Solo editable en actividades aprobadas."/>
                        </group>
                        <group>
                            <field name="total_estudiantes" readonly="1"/>
                        </group>
                    </group>

                    <!-- Sección 4: Cupo -->
                    <group string="Cupo de Participantes">
                        <group>
                            <field name="cupo_ilimitado"
                                   readonly="estado_actividad != 'aprobada'"/>
                        </group>
                        <group invisible="cupo_ilimitado">
                            <field name="cupo_min"
                                   readonly="estado_actividad != 'aprobada'"
                                   string="Cupo Mínimo"/>
                            <field name="cupo_max"
                                   readonly="estado_actividad != 'aprobada'"
                                   string="Cupo Máximo"/>
                        </group>
                        <div class="text-muted" invisible="not cupo_ilimitado">
                            <i class="fa fa-infinity"/>
                            <strong> Cupo ilimitado</strong> — Curso masivo.
                        </div>
                    </group>

                    <!-- Descripción -->
                    <group string="Descripción">
                        <field name="descripcion"
                               nolabel="1"
                               colspan="2"
                               readonly="estado_actividad != 'aprobada' and estado_actividad != 'pendiente_inicio' and estado_actividad != 'en_curso'"
                               placeholder="Descripción de la actividad…"/>
                    </group>

                    <!-- Tabs: horarios, estudiantes, evidencias, constancias -->
                    <notebook>

                        <page string="Horarios" name="horarios">
                            <field name="horario_ids"
                                   readonly="estado_actividad != 'aprobada' and estado_actividad != 'pendiente_inicio' and estado_actividad != 'en_curso'">
                                <list editable="bottom">
                                    <field name="dia_semana"/>
                                    <field name="hora_inicio" widget="float_time"/>
                                    <field name="hora_fin" widget="float_time"/>
                                </list>
                            </field>
                        </page>

                        <page string="Lista de Estudiantes" name="estudiantes">
                            <div class="alert alert-warning"
                                 invisible="responsable_actividad_id != False">
                                <i class="fa fa-warning"/>
                                Debe asignar un <strong>Responsable de Actividad</strong>
                                antes de inscribir estudiantes.
                            </div>
                            <field name="lista_estudiante_ids"
                                   readonly="estado_actividad != 'aprobada'"
                                   invisible="responsable_actividad_id == False">
                                <list editable="bottom"
                                      decoration-success="nivel_desempeno == 'excelente' or nivel_desempeno == 'bueno'"
                                      decoration-warning="nivel_desempeno == 'regular'"
                                      decoration-danger="nivel_desempeno == 'deficiente'">
                                    <field name="estudiante_id"
                                           options="{'no_create': True}"/>
                                    <field name="periodo_id" optional="hide"/>
                                    <field name="nivel_desempeno"
                                           readonly="parent.estado_actividad != 'en_curso' and parent.estado_actividad != 'finalizada'"/>
                                    <field name="constancia_id" optional="hide" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <page string="Evidencias" name="evidencias">
                            <field name="evidencia_ids"
                                   readonly="estado_actividad != 'en_curso' and estado_actividad != 'finalizada'">
                                <list>
                                    <field name="estudiante_id" options="{'no_create': True}"/>
                                    <field name="ruta_archivo_filename"/>
                                    <field name="fecha_carga"/>
                                    <field name="ruta_archivo" widget="binary" filename="ruta_archivo_filename"/>
                                </list>
                            </field>
                        </page>

                        <page string="Constancias" name="constancias"
                              invisible="estado_actividad != 'finalizada'">
                            <field name="constancia_ids" readonly="1">
                                <list decoration-success="estado_constancia == 'completa'"
                                      decoration-warning="estado_constancia == 'firmada_responsable' or estado_constancia == 'firmada_jefe'">
                                    <field name="estudiante_id"/>
                                    <field name="estado_constancia" widget="badge"
                                           decoration-success="estado_constancia == 'completa'"
                                           decoration-warning="estado_constancia in ('firmada_responsable','firmada_jefe')"
                                           decoration-secondary="estado_constancia == 'pendiente'"/>
                                    <field name="fecha_generacion"/>
                                    <field name="ruta_constancia" widget="binary"
                                           filename="ruta_constancia_filename" optional="show"/>
                                </list>
                            </field>
                        </page>

                        <page string="Propuesta de Origen" name="propuesta_origen"
                              invisible="not propuesta_id">
                            <group>
                                <field name="propuesta_id" readonly="1"/>
                            </group>
                        </page>

                    </notebook>

                </sheet>

                <!-- Chatter -->
                <chatter/>

            </form>
        </field>
    </record>
</odoo>

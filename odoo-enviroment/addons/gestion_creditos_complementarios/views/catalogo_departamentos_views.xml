<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================== -->
    <!--  Catálogo de Departamentos                    -->
    <!-- ============================================== -->

    <record id="view_catalogo_departamentos_list" model="ir.ui.view">
        <field name="name">creditos.catalogo.departamentos.list</field>
        <field name="model">creditos.catalogo.departamentos</field>
        <field name="arch" type="xml">
            <list string="Departamentos">
                <field name="nombre_departamento"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_catalogo_departamentos_form" model="ir.ui.view">
        <field name="name">creditos.catalogo.departamentos.form</field>
        <field name="model">creditos.catalogo.departamentos</field>
        <field name="arch" type="xml">
            <form string="Departamento">
                <sheet>
                    <group>
                        <field name="nombre_departamento"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_catalogo_departamentos" model="ir.actions.act_window">
        <field name="name">Departamentos</field>
        <field name="res_model">creditos.catalogo.departamentos</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

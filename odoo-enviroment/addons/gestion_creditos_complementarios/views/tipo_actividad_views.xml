<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================== -->
    <!--  Tipo de Actividad                            -->
    <!-- ============================================== -->

    <record id="view_tipo_actividad_list" model="ir.ui.view">
        <field name="name">creditos.tipo.actividad.list</field>
        <field name="model">creditos.tipo.actividad</field>
        <field name="arch" type="xml">
            <list string="Tipos de Actividad">
                <field name="nombre"/>
                <field name="es_predefinida"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tipo_actividad_form" model="ir.ui.view">
        <field name="name">creditos.tipo.actividad.form</field>
        <field name="model">creditos.tipo.actividad</field>
        <field name="arch" type="xml">
            <form string="Tipo de Actividad">
                <sheet>
                    <group>
                        <field name="nombre"/>
                        <field name="es_predefinida"
                               help="Si está activo, las actividades de este tipo no requieren aprobación del Comité Académico."/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tipo_actividad" model="ir.actions.act_window">
        <field name="name">Tipos de Actividad</field>
        <field name="res_model">creditos.tipo.actividad</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

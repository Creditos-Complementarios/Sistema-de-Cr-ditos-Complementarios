<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================== -->
    <!--  Constancias Digitales                        -->
    <!-- ============================================== -->

    <record id="view_constancia_list" model="ir.ui.view">
        <field name="name">creditos.constancia.list</field>
        <field name="model">creditos.constancia</field>
        <field name="arch" type="xml">
            <list string="Constancias"
                  decoration-success="estado_constancia == 'completa'"
                  decoration-warning="estado_constancia == 'firmada_responsable' or estado_constancia == 'firmada_jefe'">
                <field name="estudiante_id"/>
                <field name="actividad_id"/>
                <field name="estado_constancia" widget="badge"
                       decoration-success="estado_constancia == 'completa'"
                       decoration-warning="estado_constancia in ('firmada_responsable','firmada_jefe')"
                       decoration-secondary="estado_constancia == 'pendiente'"/>
                <field name="fecha_generacion"/>
            </list>
        </field>
    </record>

    <record id="view_constancia_form" model="ir.ui.view">
        <field name="name">creditos.constancia.form</field>
        <field name="model">creditos.constancia</field>
        <field name="arch" type="xml">
            <form string="Constancia de Actividad Complementaria">
                <header>
                    <field name="estado_constancia" widget="statusbar"
                           statusbar_visible="pendiente,firmada_responsable,firmada_jefe,completa"/>
                </header>
                <sheet>
                    <group string="Datos de la Constancia">
                        <group>
                            <field name="estudiante_id" readonly="1"/>
                            <field name="actividad_id" readonly="1"/>
                            <field name="expediente_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="fecha_generacion" readonly="1"/>
                            <field name="estado_constancia" readonly="1"/>
                        </group>
                    </group>
                    <group string="Firmas Electrónicas">
                        <group>
                            <field name="firma_jefe_depto" widget="image"
                                   string="Firma Jefe de Departamento"
                                   readonly="1"/>
                        </group>
                        <group>
                            <field name="firma_responsable" widget="image"
                                   string="Firma Responsable de Actividad"
                                   readonly="1"/>
                        </group>
                    </group>
                    <group string="Documento PDF">
                        <field name="ruta_constancia" widget="binary"
                               filename="ruta_constancia_filename"/>
                        <field name="ruta_constancia_filename" invisible="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_constancia" model="ir.actions.act_window">
        <field name="name">Constancias</field>
        <field name="res_model">creditos.constancia</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

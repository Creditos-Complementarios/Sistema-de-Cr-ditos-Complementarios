<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ======================================================= -->
        <!--  Grupos de acceso (Odoo 19: res.groups sin           -->
        <!--  category_id ni comment — campos eliminados)         -->
        <!-- ======================================================= -->

        <!-- Jefe de Departamento -->
        <record id="group_jefe_departamento" model="res.groups">
            <field name="name">CC / Jefe de Departamento</field>
        </record>

        <!-- Coordinador de Carrera -->
        <record id="group_coordinador_carrera" model="res.groups">
            <field name="name">CC / Coordinador de Carrera</field>
        </record>

        <!-- Comité Académico -->
        <record id="group_comite_academico" model="res.groups">
            <field name="name">CC / Comité Académico</field>
        </record>

        <!-- Responsable de Actividad -->
        <record id="group_responsable_actividad" model="res.groups">
            <field name="name">CC / Responsable de Actividad</field>
        </record>

        <!-- Estudiante -->
        <record id="group_estudiante" model="res.groups">
            <field name="name">CC / Estudiante</field>
        </record>

        <!-- Administrador del módulo ? hereda todos los anteriores -->
        <record id="group_admin_creditos" model="res.groups">
            <field name="name">CC / Administrador</field>
            <field name="implied_ids" eval="[
                Command.link(ref('group_jefe_departamento')),
                Command.link(ref('group_coordinador_carrera')),
                Command.link(ref('group_comite_academico')),
                Command.link(ref('group_responsable_actividad')),
            ]"/>
        </record>

    </data>
</odoo>

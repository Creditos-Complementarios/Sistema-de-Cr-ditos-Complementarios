<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ========================================================== -->
        <!--  Reglas de acceso por registro (ir.rule)                  -->
        <!--  El Jefe de Departamento solo ve sus propios registros.    -->
        <!--  El Comité ve todas las propuestas.                        -->
        <!-- ========================================================== -->

        <!-- Propuestas: Jefe solo ve las de su departamento -->
        <record id="rule_propuesta_jefe_depto" model="ir.rule">
            <field name="name">Propuesta: Jefe ve solo su departamento</field>
            <field name="model_id" ref="model_creditos_propuesta_actividad"/>
            <field name="groups" eval="[(4, ref('gestion_creditos_complementarios.group_jefe_departamento'))]"/>
            <field name="domain_force">
                [('jefe_departamento_id.user_id', '=', user.id)]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Propuestas: Comité ve todas -->
        <record id="rule_propuesta_comite_all" model="ir.rule">
            <field name="name">Propuesta: Comité ve todas</field>
            <field name="model_id" ref="model_creditos_propuesta_actividad"/>
            <field name="groups" eval="[(4, ref('gestion_creditos_complementarios.group_comite_academico'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Actividad: Jefe solo ve las de su departamento -->
        <record id="rule_actividad_jefe_depto" model="ir.rule">
            <field name="name">Actividad: Jefe ve solo su departamento</field>
            <field name="model_id" ref="model_creditos_actividad_complementaria"/>
            <field name="groups" eval="[(4, ref('gestion_creditos_complementarios.group_jefe_departamento'))]"/>
            <field name="domain_force">
                [('jefe_departamento_id.user_id', '=', user.id)]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Actividad: Responsable solo ve las que tiene asignadas -->
        <record id="rule_actividad_responsable" model="ir.rule">
            <field name="name">Actividad: Responsable ve solo las asignadas a él</field>
            <field name="model_id" ref="model_creditos_actividad_complementaria"/>
            <field name="groups" eval="[(4, ref('gestion_creditos_complementarios.group_responsable_actividad'))]"/>
            <field name="domain_force">
                [('responsable_actividad_id.user_id', '=', user.id)]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Constancias: Jefe de departamento solo ve las de su departamento -->
        <record id="rule_constancia_jefe_depto" model="ir.rule">
            <field name="name">Constancia: Jefe ve solo su departamento</field>
            <field name="model_id" ref="model_creditos_constancia"/>
            <field name="groups" eval="[(4, ref('gestion_creditos_complementarios.group_jefe_departamento'))]"/>
            <field name="domain_force">
                [('actividad_id.jefe_departamento_id.user_id', '=', user.id)]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>

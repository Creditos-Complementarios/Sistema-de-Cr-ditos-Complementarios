<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FIXED: Wizard form view moved here from actividad_search_views.xml.
         Views should live in the file that matches their model. -->
    <record id="view_wizard_difusion_form" model="ir.ui.view">
        <field name="name">creditos.wizard.difusion.form</field>
        <field name="model">creditos.wizard.difusion</field>
        <field name="arch" type="xml">
            <form string="Difundir Actividad Complementaria">
                <sheet>
                    <group string="Actividad a Difundir">
                        <field name="actividad_id" readonly="1"/>
                    </group>
                    <group string="Filtrar Estudiantes">
                        <group>
                            <field name="carrera_id" options="{'no_create': True}"/>
                            <field name="semestre"/>
                        </group>
                        <group>
                            <field name="grupo"/>
                        </group>
                    </group>
                    <group string="Estudiantes Seleccionados">
                        <field name="estudiante_ids" nolabel="1" widget="many2many_tags"
                               options="{'no_create': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_difundir"
                            string="Enviar Invitaciones"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

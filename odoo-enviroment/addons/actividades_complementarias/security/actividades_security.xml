<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_admin_actividades" model="res.groups">
        <field name="name">Administrador de Actividades Complementarias</field>
    </record>

    <record id="group_jefe_departamento" model="res.groups">
        <field name="name">Jefe de Departamento</field>
    </record>

    <record id="group_comite_academico" model="res.groups">
        <field name="name">Comité Académico</field>
    </record>

    <record id="group_personal_departamento" model="res.groups">
        <field name="name">Personal de Departamento</field>
    </record>

    <data noupdate="1">
        <!-- Asignar grupo admin al usuario administrador -->
        <record id="base.user_admin" model="res.users">
            <field name="groups_id" eval="[(4, ref('actividades_complementarias.group_admin_actividades'))]"/>
        </record>
    </data>

</odoo>

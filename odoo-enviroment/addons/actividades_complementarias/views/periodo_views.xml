<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_periodo_list" model="ir.ui.view">
        <field name="name">actividad.periodo.list</field>
        <field name="model">actividad.periodo</field>
        <field name="arch" type="xml">
            <list string="Periodos Escolares" editable="bottom">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_periodo_form" model="ir.ui.view">
        <field name="name">actividad.periodo.form</field>
        <field name="model">actividad.periodo</field>
        <field name="arch" type="xml">
            <form string="Periodo Escolar">
                <sheet>
                    <group>
                        <field name="name" placeholder="Ej: 2025-2026, 2025-A"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_periodo" model="ir.actions.act_window">
        <field name="name">Periodos Escolares</field>
        <field name="res_model">actividad.periodo</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
